# frozen_string_literal: true

require "bundler/gem_tasks"

begin
  require "rspec/core/rake_task"
  RSpec::Core::RakeTask.new(:spec)
  task default: :spec
rescue LoadError
  # rspec is a dev dep; bundle install must run before `rake spec` is usable.
end

namespace :native do
  # Copies the freshly-built native lib from the workspace target/ directory
  # into ext/blazen/ so the packaged gem contains it.
  desc "Refresh ext/blazen/libblazen_uniffi.* from target/release/"
  task :refresh do
    root = File.expand_path("../..", __dir__)
    src_dir = File.join(root, "target", "release")
    dst_dir = File.expand_path("ext/blazen", __dir__)
    FileUtils.mkdir_p(dst_dir)
    %w[libblazen_uniffi.so libblazen_uniffi.dylib libblazen_uniffi.dll].each do |name|
      src = File.join(src_dir, name)
      next unless File.exist?(src)

      FileUtils.cp(src, File.join(dst_dir, name))
      puts "  copied #{name}"
    end
  end

  # Regenerates the autogenerated UniFFI Ruby glue from the freshly-built
  # native lib's metadata. Run after any change to blazen-uniffi.
  desc "Regenerate lib/uniffi/blazen/blazen.rb from the native lib"
  task :regen do
    root = File.expand_path("../..", __dir__)
    bindgen = File.join(root, "target", "release", "uniffi-bindgen")
    # NB: UniFFI's library-mode bindgen reads scaffolding metadata symbols
    # from the symbol table; the cdylib is stripped (no .dynsym entries for
    # these), so we hand it the static archive instead.
    lib = File.join(root, "target", "release", "libblazen_uniffi.a")
    cfg = File.join(root, "crates", "blazen-uniffi", "uniffi.toml")
    out = File.expand_path("lib/uniffi/blazen", __dir__)
    FileUtils.mkdir_p(out)
    sh bindgen, "generate", "--library", lib, "--language", "ruby",
       "--config", cfg, "--out-dir", out
  end
end

desc "Build the gem (refreshes the native lib first)"
task build: ["native:refresh"]

desc "Push the gem to RubyGems"
task :release do
  Rake::Task["build"].invoke
  sh "gem push pkg/blazen-#{Blazen::VERSION}.gem"
end
