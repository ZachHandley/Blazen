# frozen_string_literal: true

begin
  require "bundler/gem_tasks"
rescue LoadError
  # `bundler` provides `gem build`/`gem release` rake tasks. Optional locally;
  # CI installs bundler explicitly. Without it, only the native:* tasks below
  # and `rake spec` (if rspec is available) are usable.
end

begin
  require "rspec/core/rake_task"
  RSpec::Core::RakeTask.new(:spec)
  task default: :spec
rescue LoadError
  # rspec is a dev dep; bundle install must run before `rake spec` is usable.
end

namespace :native do
  # Copies the freshly-built native lib from the workspace target/ directory
  # into ext/blazen/ so the packaged gem contains it.
  #
  # The Ruby gem links against `libblazen_cabi` (cbindgen + C ABI cdylib over
  # blazen-uniffi's types), NOT `libblazen_uniffi`. See lib/blazen/ffi.rb.
  desc "Refresh ext/blazen/libblazen_cabi.* from target/release/"
  task :refresh do
    root = File.expand_path("../..", __dir__)
    src_dir = File.join(root, "target", "release")
    dst_dir = File.expand_path("ext/blazen", __dir__)
    FileUtils.mkdir_p(dst_dir)
    %w[libblazen_cabi.so libblazen_cabi.dylib libblazen_cabi.dll blazen_cabi.dll].each do |name|
      src = File.join(src_dir, name)
      next unless File.exist?(src)

      FileUtils.cp(src, File.join(dst_dir, name))
      puts "  copied #{name}"
    end
  end

  # Rebuilds blazen-cabi, which (via its build.rs invoking cbindgen) regenerates
  # ext/blazen/blazen.h. Run after any change to crates/blazen-cabi/.
  desc "Regenerate ext/blazen/blazen.h via cargo build -p blazen-cabi"
  task :regen do
    root = File.expand_path("../..", __dir__)
    sh "cargo", "build", "-p", "blazen-cabi", "--release", chdir: root
  end
end

desc "Build the gem (refreshes the native lib first)"
task build: ["native:refresh"]

desc "Push the gem to RubyGems"
task :release do
  Rake::Task["build"].invoke
  sh "gem push pkg/blazen-#{Blazen::VERSION}.gem"
end
