# Track local-wasi/package.json (the stub stage-local-blazen.sh writes) so
# pnpm install on a fresh CI checkout can resolve the file: override before
# stage-local-blazen.sh has had a chance to run. Generated wasi artefacts
# stay ignored — they're regenerated by `pnpm --filter blazen run build`
# and copied in by the stage script.
local-wasi/*.wasm
local-wasi/*.cjs
local-wasi/*.js
