{
  "name": "blazen-astro-cloudflare-smoke",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Astro 6 + @astrojs/cloudflare smoke test for the `blazen` npm package. Verifies that `import { CompletionModel } from 'blazen'` works in a workerd bundle WITHOUT any consumer-side Vite/Rollup workaround plugins.",
  "scripts": {
    "stage-local-blazen": "bash scripts/stage-local-blazen.sh",
    "predev": "pnpm run stage-local-blazen",
    "prebuild": "pnpm run stage-local-blazen",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev --port 8787",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.0.0",
    "astro": "^6.3.0",
    "blazen": "workspace:*",
    "@blazen-dev/blazen-wasm32-wasi": "file:./local-wasi"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.90.1"
  }
}
