{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "rust",
        "python",
        "node",
        "wasm"
      ]
    },
    "section": {
      "type": "string",
      "enum": [
        "getting-started",
        "guides",
        "api",
        "examples"
      ]
    },
    "order": {
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "section",
    "order"
  ]
}