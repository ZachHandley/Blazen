---
import Layout from "~/layouts/Layout.astro";
import DocsNav from "~/components/global/DocsNav.astro";
import { getCollection } from "astro:content";

const docs = await getCollection("docs");
const knownRoutes = docs.map((entry) => `/docs/${entry.id}`);
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <DocsNav />

  <main class="flex min-h-[calc(100vh-4rem)] items-center justify-center px-6">
    <div class="w-full max-w-lg text-center">
      <h1 class="mb-2 text-8xl font-extrabold tracking-tight sm:text-9xl">
        <span
          class="bg-gradient-to-r from-blazen-400 via-blazen-500 to-blazen-600 bg-clip-text text-transparent"
          >404</span
        >
      </h1>
      <p class="mb-2 text-xl font-semibold text-gray-200">Page not found</p>
      <p class="mb-8 text-sm text-gray-400">
        The page you're looking for doesn't exist or may have moved.
      </p>

      <div id="suggestion" class="mb-8 hidden">
        <p class="mb-3 text-sm text-gray-400">Did you mean?</p>
        <div id="suggestion-links" class="flex flex-col items-center gap-2">
        </div>
      </div>

      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <button
          id="go-back"
          class="inline-flex items-center gap-2 rounded-lg bg-surface-700 px-6 py-3 text-sm font-medium text-gray-100 transition-colors hover:bg-surface-600"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Go back
        </button>
        <a
          href="/docs/getting-started/introduction"
          class="inline-flex items-center gap-2 rounded-lg bg-blazen-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-blazen-600"
        >
          Browse docs
        </a>
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-lg bg-surface-700 px-6 py-3 text-sm font-medium text-gray-100 transition-colors hover:bg-surface-600"
        >
          Home
        </a>
      </div>
    </div>
  </main>

  <script define:vars={{ knownRoutes }}>
    const path = window.location.pathname.replace(/\/+$/, "") || "/";
    const routeSet = new Set(knownRoutes);

    // Exact match with trailing slash difference — redirect immediately
    if (routeSet.has(path)) {
      window.location.replace(path);
    } else if (routeSet.has(path + "/")) {
      window.location.replace(path + "/");
    } else {
      // Find suggestions
      const suggestions = [];

      for (const route of knownRoutes) {
        // Prefix match: user typed a parent path
        if (route.startsWith(path + "/")) {
          suggestions.push({ route, score: 1 });
          continue;
        }

        // Compare last segment via Levenshtein for typos
        const pathParts = path.split("/").filter(Boolean);
        const routeParts = route.split("/").filter(Boolean);

        // Same parent path, similar last segment
        if (
          pathParts.length === routeParts.length &&
          pathParts.slice(0, -1).join("/") === routeParts.slice(0, -1).join("/")
        ) {
          const dist = levenshtein(
            pathParts[pathParts.length - 1],
            routeParts[routeParts.length - 1]
          );
          if (dist <= 3) {
            suggestions.push({ route, score: dist });
          }
        }
      }

      suggestions.sort((a, b) => a.score - b.score);
      const top = suggestions.slice(0, 3);

      if (top.length > 0) {
        // Single very-close match (distance 1 or prefix) — auto-redirect
        if (top.length === 1 && top[0].score <= 1) {
          window.location.replace(top[0].route);
        } else {
          const container = document.getElementById("suggestion");
          const links = document.getElementById("suggestion-links");
          if (container && links) {
            container.classList.remove("hidden");
            for (const s of top) {
              const a = document.createElement("a");
              a.href = s.route;
              a.textContent = s.route;
              a.className =
                "rounded-lg border border-surface-600 bg-surface-800 px-4 py-2 text-sm text-blazen-400 transition-colors hover:bg-surface-700 hover:text-blazen-300";
              links.appendChild(a);
            }
          }
        }
      }
    }

    function levenshtein(a, b) {
      const m = a.length;
      const n = b.length;
      const dp = Array.from({ length: m + 1 }, () => new Array(n + 1).fill(0));
      for (let i = 0; i <= m; i++) dp[i][0] = i;
      for (let j = 0; j <= n; j++) dp[0][j] = j;
      for (let i = 1; i <= m; i++) {
        for (let j = 1; j <= n; j++) {
          dp[i][j] =
            a[i - 1] === b[j - 1]
              ? dp[i - 1][j - 1]
              : 1 + Math.min(dp[i - 1][j], dp[i][j - 1], dp[i - 1][j - 1]);
        }
      }
      return dp[m][n];
    }

    document.getElementById("go-back")?.addEventListener("click", () => {
      if (window.history.length > 1) {
        window.history.back();
      } else {
        window.location.href = "/";
      }
    });
  </script>
</Layout>
