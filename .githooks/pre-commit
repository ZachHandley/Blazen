#!/usr/bin/env bash
# Pre-commit hook for Blazen.
#
# - Runs cargo fmt + clippy ONLY when Rust sources or Cargo manifests are
#   staged (keeps doc/CI/test-only commits fast).
# - Regenerates each binding's generated artefact when that binding's source
#   is staged, and stages the resulting diff back into the commit so drift
#   never reaches CI.
set -euo pipefail

STAGED="$(git diff --cached --name-only)"
[[ -z "$STAGED" ]] && exit 0

has() { echo "$STAGED" | grep -qE "$1"; }

REGEN=()

# Rust lint — both clippy invocations match CI (with and without --tests).
if has '\.rs$|(^|/)Cargo\.(toml|lock)$'; then
  echo "[pre-commit] cargo fmt --all -- --check"
  cargo fmt --all -- --check
  echo "[pre-commit] cargo clippy --workspace --all-features"
  cargo clippy --workspace --all-features -- -D warnings
  echo "[pre-commit] cargo clippy --workspace --all-features --tests"
  cargo clippy --workspace --all-features --tests -- -D warnings
fi

# Each binding's regen runs ONCE if its source is staged. Build output is left
# on stdout so a silent failure (missing feature, wrong toolchain) is visible —
# previously these all ran with `>/dev/null` and the user wouldn't see the
# build truncating the typegen. The regen output is staged into the in-progress
# commit; CI's `audit-bindings` job is the final safety net for drift.

# Python stub (.pyi)
if has '^crates/blazen-py/src/'; then
  echo "[pre-commit] regenerating crates/blazen-py/blazen.pyi"
  cargo run --example stub_gen -p blazen-py \
    --features langfuse,otlp,prometheus,tract,distributed
  REGEN+=("crates/blazen-py/blazen.pyi")
fi

# Node typegen (index.d.ts)
if has '^crates/blazen-node/src/'; then
  echo "[pre-commit] regenerating crates/blazen-node/index.d.ts"
  pnpm --filter blazen run build
  REGEN+=("crates/blazen-node/index.d.ts")
fi

# UniFFI bindings (Go/Swift/Kotlin) and cabi (Ruby C header) are regenerated
# whenever any crate that participates in their FFI surface is touched — not
# just blazen-uniffi or blazen-cabi themselves. blazen-uniffi re-exports
# types from blazen-core, blazen-llm, blazen-events, blazen-pipeline,
# blazen-telemetry, etc., so a change to any of those can ripple into the
# generated foreign-language bindings (or the cbindgen-generated Ruby C
# header). Without this broad trigger the regen silently doesn't run and
# CI's audit-bindings job catches the drift instead.
FFI_SURFACE_REGEX='^crates/blazen-(uniffi|cabi|core|events|llm|manager|memory|memory-valkey|model-cache|peer|persist|pipeline|prompts|telemetry|embed-tract)/'

if has "$FFI_SURFACE_REGEX"; then
  echo "[pre-commit] regenerating UniFFI bindings (Go/Swift/Kotlin)"
  cargo build -p blazen-uniffi --release --bin uniffi-bindgen
  cargo build -p blazen-uniffi --release
  ./scripts/regen-bindings.sh
  REGEN+=("bindings/go" "bindings/swift" "bindings/kotlin")

  echo "[pre-commit] regenerating bindings/ruby/ext/blazen/blazen.h"
  cargo build -p blazen-cabi --release
  REGEN+=("bindings/ruby/ext/blazen/blazen.h")
fi

# WASM SDK pkg/ (wasm-bindgen output). wasm-opt makes the release build
# expensive (minutes); the hook still runs it because committing a stale
# WASM `pkg/` blocks downstream consumers, but we skip the second-pass
# verification (CI's `audit-bindings` re-runs this regardless).
if has '^crates/blazen-wasm-sdk/src/'; then
  if ! command -v wasm-pack >/dev/null; then
    echo "[pre-commit] ERROR: wasm-pack not installed but crates/blazen-wasm-sdk/src/ is staged."
    echo "  Install: cargo install wasm-pack --locked"
    exit 1
  fi
  echo "[pre-commit] regenerating crates/blazen-wasm-sdk/pkg"
  wasm-pack build crates/blazen-wasm-sdk --target web --out-dir pkg --release
  REGEN+=("crates/blazen-wasm-sdk/pkg")
fi

if (( ${#REGEN[@]} > 0 )); then
  git add -- "${REGEN[@]}"
fi
