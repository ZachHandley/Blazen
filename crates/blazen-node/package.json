{
  "name": "blazen",
  "version": "0.1.0",
  "description": "Blazen - Event-driven AI workflow framework for Node.js/TypeScript",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./workers": {
      "types": "./blazen.workers.d.ts",
      "default": "./blazen.workers.js"
    },
    "./package.json": "./package.json"
  },
  "napi": {
    "binaryName": "blazen",
    "packageName": "@blazen-dev/blazen",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "wasm32-wasi"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://forge.blackleafdigital.com/BlackLeafDigital/Blazen"
  },
  "keywords": [
    "agents",
    "workflow",
    "llm",
    "ai",
    "event-driven",
    "napi-rs",
    "rust"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "error-classes.js",
    "blazen.workers.js",
    "blazen.workers.d.ts"
  ],
  "dependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@napi-rs/wasm-runtime": "^1.1.4",
    "@tybys/wasm-util": "^0.10.2"
  },
  "peerDependencies": {
    "@blazen-dev/blazen-wasm32-wasi": "^0.1.160"
  },
  "peerDependenciesMeta": {
    "@blazen-dev/blazen-wasm32-wasi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@napi-rs/cli": "^3.0.0",
    "ava": "^8.0.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --release --platform --features local-all,langfuse --js index.js && node scripts/post-build.mjs",
    "build:debug": "napi build --platform --features local-all,langfuse --js index.js && node scripts/post-build.mjs",
    "test": "ava",
    "test:workflow": "ava ../../tests/node/test_workflow.mjs",
    "test:smoke": "ava ../../tests/node/test_llm_smoke.mjs",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release"
  },
  "ava": {
    "files": [
      "../../tests/node/test_*.mjs"
    ],
    "extensions": [
      "mjs"
    ],
    "timeout": "120s",
    "concurrency": 4,
    "verbose": true
  }
}
